        "cte": "WITH prod AS (SELECT NULLIF(t.\"CLIENT_NAME\", '') AS \"CLIENT_NAME\",\n       NULLIF(t.\"CLIENT_REGION\", '') AS \"CLIENT_REGION\",\n       t.\"DOCUMENT_TEMPLATE_COLLATE_ID\" AS \"DOCUMENT_TEMPLATE_COLLATE_ID\",\n       t.\"DOCUMENT_TEMPLATE_ID\" AS \"DOCUMENT_TEMPLATE_ID\",\n       t.\"FORM_FIELD_COLLATE_ID\" AS \"FORM_FIELD_COLLATE_ID\",\n       NULLIF(t.\"DOCUMENT_COLUMN_LABEL\", '') AS \"DOCUMENT_COLUMN_LABEL\",\n       NULLIF(t.\"DOCUMENT_COLUMN_DESCRIPTION\", '') AS \"DOCUMENT_COLUMN_DESCRIPTION\",\n       NULLIF(t.\"DOCUMENT_COLUMN_TYPE\", '') AS \"DOCUMENT_COLUMN_TYPE\",\n       NULLIF(t.\"DOCUMENT_COLUMN_DATA_TYPE\", '') AS \"DOCUMENT_COLUMN_DATA_TYPE\",\n       NULLIF(t.\"DOCUMENT_COLUMN_NAME\", '') AS \"DOCUMENT_COLUMN_NAME\",\n       NULLIF(t.\"NS_DOCUMENT_COLUMN_NAME\", '') AS \"NS_DOCUMENT_COLUMN_NAME\",\n       t.\"IS_CURRENT\" AS \"IS_CURRENT\"\n       FROM PROD_DB.BI.DOCUMENT_FORM_FIELD_MAPPING t  INNER JOIN UAT_DB.BI.TEMP_ACTIVE_TENANTS AS act ON t.client_name = act.client_name AND t.client_region = act.client_region),\n     uat AS (SELECT NULLIF(t.\"CLIENT_NAME\", '') AS \"CLIENT_NAME\",\n       NULLIF(t.\"CLIENT_REGION\", '') AS \"CLIENT_REGION\",\n       t.\"DOCUMENT_TEMPLATE_COLLATE_ID\" AS \"DOCUMENT_TEMPLATE_COLLATE_ID\",\n       t.\"DOCUMENT_TEMPLATE_ID\" AS \"DOCUMENT_TEMPLATE_ID\",\n       t.\"FORM_FIELD_COLLATE_ID\" AS \"FORM_FIELD_COLLATE_ID\",\n       NULLIF(t.\"DOCUMENT_COLUMN_LABEL\", '') AS \"DOCUMENT_COLUMN_LABEL\",\n       NULLIF(t.\"DOCUMENT_COLUMN_DESCRIPTION\", '') AS \"DOCUMENT_COLUMN_DESCRIPTION\",\n       NULLIF(t.\"DOCUMENT_COLUMN_TYPE\", '') AS \"DOCUMENT_COLUMN_TYPE\",\n       NULLIF(t.\"DOCUMENT_COLUMN_DATA_TYPE\", '') AS \"DOCUMENT_COLUMN_DATA_TYPE\",\n       NULLIF(t.\"DOCUMENT_COLUMN_NAME\", '') AS \"DOCUMENT_COLUMN_NAME\",\n       NULLIF(t.\"NS_DOCUMENT_COLUMN_NAME\", '') AS \"NS_DOCUMENT_COLUMN_NAME\",\n       t.\"IS_CURRENT\" AS \"IS_CURRENT\"\n       FROM UAT_DB.BI.DOCUMENT_FORM_FIELD_MAPPING t  IN