# Copy to .env (git-ignore it). Values here are defaults from your setup.
SNOWFLAKE_ACCOUNT=lh48692.ap-southeast-2.privatelink
SNOWFLAKE_USER=graham.crawford@elmosoftware.com.au
SNOWFLAKE_WAREHOUSE=BI_WH
SNOWFLAKE_ROLE=

# SSO via browser (Okta/AAD). Token is cached locally so re-runs don't re-prompt.
SNOWFLAKE_AUTHENTICATOR=externalbrowser

# Only needed if NOT using externalbrowser:
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_PRIVATE_KEY_PATH=
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

# Note: SNOWFLAKE_DATABASE / SNOWFLAKE_SCHEMA are not needed — every query is
# fully qualified from environments.prod_db / uat_db / schema in config.yaml.
